# --- Database ---
# Local dev (SQLite): provider = "sqlite" in prisma/schema.prisma
DATABASE_URL="file:./dev.db"
# Production (Supabase Postgres): set provider = "postgresql" + add directUrl to the datasource.
#   DATABASE_URL = Supavisor pooler (port 6543), runtime — MUST append ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = direct connection (port 5432), used only by `prisma migrate`
# DATABASE_URL="postgresql://postgres.<ref>:<pw>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<ref>:<pw>@<region>.pooler.supabase.com:5432/postgres"

AUTH_SECRET="generate-with: openssl rand -base64 32"
APP_URL="http://localhost:3000"

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."        # local: stripe listen --forward-to localhost:3000/api/payments/webhook
STRIPE_PAID_ACCESS_PRICE_ID="price_..."
STRIPE_FLIGHT_REVIEW_PRICE_ID="price_..."  # the Flight Review add-on product price

# Resend — get from resend.com (free tier: 3000 emails/month)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"      # must be a verified sender domain in Resend
ADMIN_NOTIFICATION_EMAIL="admin@yourdomain.com"  # receives flight-review booking notifications

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
