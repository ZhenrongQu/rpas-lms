# ─────────────────────────────────────────────────────────────────────────────
# Template — copy to environment-specific files (both are gitignored):
#   .env             → local dev   (Stripe TEST / sandbox mode; dev DB)
#   .env.production  → production  (Stripe LIVE mode; prod DB)  [or set in Vercel]
# Price IDs must come from the matching Stripe mode: TEST ids in .env, LIVE ids
# in .env.production. Next.js loads .env first, then .env.<NODE_ENV> over it.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database ---
# Local dev (SQLite): provider = "sqlite" in prisma/schema.prisma
DATABASE_URL="file:./dev.db"
# Production (Supabase Postgres): set provider = "postgresql" + add directUrl to the datasource.
#   DATABASE_URL = Supavisor pooler (port 6543), runtime — MUST append ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = direct connection (port 5432), used only by `prisma migrate`
# DATABASE_URL="postgresql://postgres.<ref>:<pw>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<ref>:<pw>@<region>.pooler.supabase.com:5432/postgres"

AUTH_SECRET="generate-with: openssl rand -base64 32"
APP_URL="http://localhost:3000"

# Stripe — dashboard.stripe.com. Use TEST keys/prices in .env, LIVE in .env.production.
STRIPE_SECRET_KEY="sk_test_..."          # sk_test_… (dev) / sk_live_… or rk_live_… (prod)
STRIPE_WEBHOOK_SECRET="whsec_..."        # local: stripe listen --forward-to localhost:3000/api/payments/webhook
STRIPE_PAID_ACCESS_PRICE_ID="price_..."  # price id from the SAME Stripe mode as the secret key
STRIPE_FLIGHT_REVIEW_PRICE_ID="price_..." # the Flight Review add-on product price (test id in .env, live in .env.production)

# Resend — get from resend.com (free tier: 3000 emails/month)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"      # must be a verified sender domain in Resend
ADMIN_NOTIFICATION_EMAIL="admin@yourdomain.com"  # receives flight-review booking notifications

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# --- Sentry error monitoring (optional) ---
# DSN is public (safe to expose to the browser). Without it, Sentry no-ops.
NEXT_PUBLIC_SENTRY_DSN=""
# The three below are build-time only (source map upload). AUTH_TOKEN is secret.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
