generator client {
  provider        = "prisma-client-js"
  // postgresqlExtensions lets `prisma db push`/migrate manage the pgvector
  // extension (declared on the datasource) so the KnowledgeChunk vector column
  // can be created on both Supabase and the local pgvector test container.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Identity ────────────────────────────────────────────────────────────────
// Admins and customers are now physically separate tables. There is no shared
// `role` field, so a customer row can never be escalated to admin. Admins have
// their own credential login (see auth.ts "admin" provider); they own no
// learning/payment data.

model Admin {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String?   @unique
  hashedPassword String
  displayName    String?   @map("name")
  // SEC-16: TOTP MFA. `totpSecret` holds a pending or active base32 secret;
  // `totpEnabledAt` is set only once the admin confirms a code, after which the
  // second factor is required at login.
  totpSecret     String?
  totpEnabledAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Customer {
  id               String                   @id @default(cuid())
  userNumber       Int?                     @unique // switch to @default(autoincrement()) on PostgreSQL
  username         String?                  @unique
  email            String?                  @unique
  phone            String?                  @unique
  displayName      String?                  @map("name")
  hashedPassword   String?
  accessTier       String                   @default("FREE")
  stripeCustomerId String?
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  identities       UserIdentity[]
  examSessions     ExamSession[]
  mobileSessions   MobileSession[]
  basicProgress    BasicLessonProgress[]
  advancedProgress AdvancedLessonProgress[]
  payments         Payment[]
  entitlements     Entitlement[]
  flightReviewBooking FlightReviewBooking?
}

model UserIdentity {
  id                String    @id @default(cuid())
  userId            String
  user              Customer  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model MobileSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      Customer  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model VerificationCode {
  id         String    @id @default(cuid())
  target     String
  channel    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([target, channel])
}

// SEC-10/11: shared, fixed-window counters for login lockout and endpoint
// throttling. Lives in the DB (not memory) so the limit holds across Vercel's
// stateless instances. `key` encodes the scope, e.g. "login:acct:<email>",
// "login:ip:<ip>", "send-code:ip:<ip>". A row is reset when its window expires.
model RateLimit {
  key         String    @id
  count       Int       @default(0)
  windowStart DateTime  @default(now())
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([lockedUntil])
}

model ExamSession {
  id               String    @id
  userId           String?
  user             Customer? @relation(fields: [userId], references: [id])
  certLevel        String
  locale           String
  questionIds      String // JSON: string[]
  questionSnapshot String    @default("[]") // JSON: Question[] captured at exam creation; grading/review reads this
  answers          String    @default("{}") // JSON: Record<string, string[]>
  startedAt        DateTime
  expiresAt        DateTime
  submitted        Boolean   @default(false)
  result           String? // JSON: ExamResult
  createdAt        DateTime  @default(now())

  @@index([userId])
}

model Payment {
  id                      String   @id @default(cuid())
  userId                  String
  user                    Customer @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCheckoutSessionId String   @unique
  stripePaymentIntentId   String?  @unique
  stripeCustomerId        String?
  product                 String
  amountTotal             Int?
  currency                String?
  status                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
  @@index([product])
}

model Entitlement {
  id        String    @id @default(cuid())
  userId    String
  user      Customer  @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   String
  source    String
  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([product])
  @@unique([userId, product])
}

model WebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

// ─── Flight Review booking ───────────────────────────────────────────────────
// Admins publish discrete dated slots (each carrying its own location + examiner);
// an eligible student books exactly one. A booking row's existence == an active
// booking: cancelling deletes the row (slot reopens), rescheduling moves slotId.
// `slotId @unique` makes double-booking impossible at the DB level.

model FlightReviewSlot {
  id            String               @id @default(cuid())
  startsAt      DateTime // stored UTC
  durationMin   Int                  @default(60)
  location      String
  examinerName  String
  examinerEmail String?
  examinerPhone String?
  notes         String?
  status        String               @default("ACTIVE") // "ACTIVE" | "ARCHIVED"
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  booking       FlightReviewBooking?

  @@index([startsAt])
}

model FlightReviewBooking {
  id         String           @id @default(cuid())
  slotId     String           @unique // one booking per slot → blocks double-booking
  slot       FlightReviewSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  customerId String           @unique // one active booking per student
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

// ─── Question banks (split by certification level) ───────────────────────────
// Basic and advanced questions live in physically separate banks. There is no
// "BOTH" — every question belongs to exactly one bank. The `certLevel` column is
// retained for app/mapper compatibility and is always equal to the bank's level.

model BasicQuestionBank {
  id          String                @id // "air-law-0001" format — preserves ExamSession refs
  moduleId    String
  certLevel   String                @default("BASIC") // always "BASIC"
  type        String // "SINGLE" | "MULTI"
  selectCount Int
  difficulty  Int
  stemEN      String
  stemZH      String
  explEN      String
  explZH      String
  refEN       String
  refZH       String
  tags        String                @default("[]") // JSON: string[]
  mediaKind   String?
  mediaUrl    String?
  mediaAltEN  String?
  mediaAltZH  String?
  status      String                @default("ACTIVE") // "ACTIVE" | "ARCHIVED"; exam generation only uses ACTIVE
  archivedAt  DateTime?
  options     BasicQuestionOption[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([moduleId])
}

model AdvancedQuestionBank {
  id          String                   @id
  moduleId    String
  certLevel   String                   @default("ADVANCED") // always "ADVANCED"
  type        String
  selectCount Int
  difficulty  Int
  stemEN      String
  stemZH      String
  explEN      String
  explZH      String
  refEN       String
  refZH       String
  tags        String                   @default("[]")
  mediaKind   String?
  mediaUrl    String?
  mediaAltEN  String?
  mediaAltZH  String?
  status      String                   @default("ACTIVE")
  archivedAt  DateTime?
  options     AdvancedQuestionOption[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([moduleId])
}

model BasicQuestionOption {
  id         String            @id @default(cuid())
  questionId String
  optionId   String // "a" | "b" | "c" | "d"
  labelEN    String
  labelZH    String
  isCorrect  Boolean
  question   BasicQuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionId])
  @@index([questionId])
}

model AdvancedQuestionOption {
  id         String               @id @default(cuid())
  questionId String
  optionId   String
  labelEN    String
  labelZH    String
  isCorrect  Boolean
  question   AdvancedQuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionId])
  @@index([questionId])
}

// ─── Checkpoint questions (lesson practice, separate from the exam banks) ─────
// Physically separate from BasicQuestionBank/AdvancedQuestionBank so the public
// checkpoint endpoints can never reach exam answers (SEC-04). Each checkpoint is
// assigned to one lesson via `lessonId` and renders at the bottom of that lesson.
model CheckpointQuestion {
  id          String                     @id // "cp-air-law-0001"
  lessonId    String // assignment target: "${course}/${moduleId}/${slug}"
  course      String // "basic" | "advanced" (denormalized for filtering)
  moduleId    String // denormalized for CMS list filtering
  order       Int                        @default(0) // position among a lesson's checkpoints
  type        String // "SINGLE" | "MULTI"
  selectCount Int
  stemEN      String
  stemZH      String
  explEN      String
  explZH      String
  refEN       String
  refZH       String
  tags        String                     @default("[]") // JSON: string[]
  mediaKind   String?
  mediaUrl    String?
  mediaAltEN  String?
  mediaAltZH  String?
  status      String                     @default("ACTIVE") // "ACTIVE" | "ARCHIVED"
  archivedAt  DateTime?
  options     CheckpointQuestionOption[]
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([lessonId])
  @@index([course, moduleId])
}

model CheckpointQuestionOption {
  id         String             @id @default(cuid())
  questionId String
  optionId   String
  labelEN    String
  labelZH    String
  isCorrect  Boolean
  question   CheckpointQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionId])
  @@index([questionId])
}

// ─── Lessons (split by course) ───────────────────────────────────────────────
// Basic and advanced lessons live in physically separate tables. The `course`
// column is retained for app/mapper compatibility and is always equal to the
// table's course. `lessonId` ("${course}/${moduleId}/${slug}") stays the stable
// external identifier used across the completion UI and as the progress FK.

model BasicLesson {
  id         String                @id @default(cuid())
  lessonId   String                @unique // "${course}/${moduleId}/${slug}"
  course     String                @default("basic") // always "basic"
  moduleId   String
  slug       String
  order      Int
  estMinutes Int
  certLevel  String // "BASIC" | "ADVANCED" | "BOTH" (lesson tag; orthogonal to course)
  access     String // "FREE" | "PAID"
  titleEN    String
  titleZH    String
  bodyEN     String // raw MDX body (frontmatter stripped)
  bodyZH     String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  videoUid          String?
  videoStatus       String?               // "PROCESSING" | "READY" | "ERROR"
  videoDurationSec  Int?
  videoThumbnailUrl String?
  progress          BasicLessonProgress[]

  @@unique([course, moduleId, slug])
  @@index([course, moduleId])
}

model AdvancedLesson {
  id         String                   @id @default(cuid())
  lessonId   String                   @unique
  course     String                   @default("advanced") // always "advanced"
  moduleId   String
  slug       String
  order      Int
  estMinutes Int
  certLevel  String
  access     String
  titleEN    String
  titleZH    String
  bodyEN     String
  bodyZH     String
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  videoUid          String?
  videoStatus       String?                  // "PROCESSING" | "READY" | "ERROR"
  videoDurationSec  Int?
  videoThumbnailUrl String?
  progress          AdvancedLessonProgress[]

  @@unique([course, moduleId, slug])
  @@index([course, moduleId])
}

model BasicLessonProgress {
  id          String      @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime    @default(now())
  user        Customer    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      BasicLesson @relation(fields: [lessonId], references: [lessonId], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model AdvancedLessonProgress {
  id          String         @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime       @default(now())
  user        Customer       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      AdvancedLesson @relation(fields: [lessonId], references: [lessonId], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// Remediation kernel — durable state for the auto-fix remediation pipeline.
// An Incident is the deduplicated identity of a production signal; a RemediationRun is one
// lease-guarded workflow cycle whose phase advances via CAS transitions.
model Incident {
  id              String           @id @default(cuid())
  repository      String
  defaultBranch   String
  fingerprint     String
  occurrenceCount Int              @default(1)
  latestPayload   String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  runs            RemediationRun[]
  externalActions ExternalAction[]

  @@unique([repository, defaultBranch, fingerprint])
}

model RemediationRun {
  id             String    @id @default(cuid())
  incidentId     String
  incident       Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  cycle          Int       @default(1)
  phase          String    @default("RECEIVED")
  leaseOwner     String?
  leaseExpiresAt DateTime?
  escalatedAt    DateTime?
  evidence       String? // persisted RepairEvidence JSON (resume buffer for verify/publish)
  target         Json? // immutable repair target, frozen at REPRODUCING→FIXING; resume must match it
  policy         Json? // frozen repair/verify policy, snapshotted at first repair; resume runs under the same rules
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([incidentId, cycle])
  @@index([incidentId])
  @@index([phase, leaseExpiresAt])
}

// A remediation proposal (mock Draft PR). Stable identity per (incident, kind);
// each verified cycle is an append-only version, never rewritten. currentVersion
// is advanced with an atomic GREATEST so concurrent cycles stay monotonic.
model ExternalAction {
  id             String                  @id @default(cuid())
  kind           String // "draft_pr"
  incidentId     String
  incident       Incident                @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  repository     String
  defaultBranch  String
  fingerprint    String
  status         String                  @default("open")
  currentVersion Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  versions       ExternalActionVersion[]

  @@unique([incidentId, kind])
}

model ExternalActionVersion {
  id        String         @id @default(cuid())
  actionId  String
  action    ExternalAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  cycle     Int
  version   Int
  body      String
  patch     String
  evidence  String
  createdAt DateTime       @default(now())

  @@unique([actionId, version])
  @@unique([actionId, cycle])
}

// ─── RAG knowledge base ──────────────────────────────────────────────────────
// Chunked, embedded corpus backing the chat assistant's `search_course_content`
// tool (hybrid semantic + keyword retrieval). Course lessons and externally
// ingested documents share this table, distinguished by `source`. Chunks are
// stored per-locale (EN/ZH separately) so retrieval stays in the reply language.
// `embedding` is a pgvector column (voyage-3.5, 1024-dim); its HNSW cosine index
// is created out-of-band by the reindex script (Prisma can't declare it).
model KnowledgeChunk {
  id         String                       @id @default(cuid())
  source     String // "LESSON" | "DOCUMENT"
  sourceId   String // lessonId, or a document slug
  moduleId   String?
  certLevel  String? // "BASIC" | "ADVANCED" | null
  locale     String // "EN" | "ZH"
  title      String
  content    String // the chunk text
  chunkIndex Int
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  @@unique([source, sourceId, locale, chunkIndex])
  @@index([locale])
}
