node_modules/
.next/
dist/
*.log
.DS_Store
coverage/
.worktrees/

# Next.js generated
next-env.d.ts
*.tsbuildinfo

# Prisma local databases
prisma/*.db
prisma/*.db-journal

# Env files — never commit secrets. Only .env.example (the template) is tracked.
.env
.env.*
!.env.example

.vercel

# Sentry
.sentryclirc
.env.sentry-build-plugin

# Database dumps — may contain user/payment data, never commit
*.dump

# Claude Code agent settings — machine-specific tool allowlist / local paths.
# Not for committing (broad command perms shouldn't be a project artifact).
.claude/settings.json
.claude/settings.local.json

# Internal docs — kept local only. Only root README.md and CLAUDE.md are tracked.
*.md
!/README.md
!/CLAUDE.md

# Operational/seed scripts — kept local only (read secrets from env at runtime).
scripts/
